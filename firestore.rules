rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only authenticated admin can write settings, anyone can read
    match /settings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Only authenticated admin can write portfolio, anyone can read
    match /portfolio/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Anyone can create a message, only admin can read, update, or delete
    match /messages/{document=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
